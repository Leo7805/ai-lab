{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureSpeech": {
    "Region": "australiaeast"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://192.168.0.109:3000",
      "http://localhost:5173",
      "http://localhost:5174",
      "https://localhost:5174",
      "https://tts-studio-ashen.vercel.app",
      "https://tts.jinleo.dev"
    ]
  },
  "Tts": {
    "MaxTextLength": 3000,
    "DefaultEnglishVoiceName": "en-US-JennyNeural",
    "DefaultChineseVoiceName": "zh-CN-XiaoxiaoNeural",
    "DefaultSpeakingRate": 1.0
  },
  "ConnectionStrings": {
    "Default": "Data Source=Data/tts-studio.db",
    "UsageDb": "Data Source=Data/usage.db"
  },
  "Usage": {
    "Provider": "azure",
    "MonthlyCharQuota": 500000
  }
}
